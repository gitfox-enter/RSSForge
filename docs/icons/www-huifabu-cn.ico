<script>
var CAT_LABELS={"zuankeba":"赚客吧","yangmaodang":"酷安","kanong":"卡农羊毛","xinzuanba":"新赚吧","douban":"豆瓣线报","weibochaohua":"微博超话","peiqi":"佩奇线报","mogu":"蘑菇","gaibang":"丐帮","xiaodigu":"小嘀咕","weibo":"微博线报","iqnew":"爱Q生活","haodan":"好单线报","huishou":"回收报价","other":"其他"};
var CAT_CHARS={"zuankeba":{"char":"赚吧","color":"#e67e22"},"yangmaodang":{"char":"酷安","color":"#1abc9c"},"kanong":{"char":"卡农","color":"#0984e3"},"xinzuanba":{"char":"新赚","color":"#e67e22"},"douban":{"char":"豆瓣","color":"#2ecc71"},"weibochaohua":{"char":"超话","color":"#e74c3c"},"peiqi":{"char":"佩奇","color":"#fd79a8"},"mogu":{"char":"蘑菇","color":"#00b894"},"gaibang":{"char":"丐帮","color":"#6c5ce7"},"huishou":{"char":"回收","color":"#e17055"},"xiaodigu":{"char":"嘀咕","color":"#00b894"},"weibo":{"char":"微博","color":"#e84393"},"iqnew":{"char":"爱Q","color":"#6c5ce7"},"haodan":{"char":"好单","color":"#27ae60"},"other":{"char":"其他","color":"#636e72"}};
var PAGE_SIZE=100;
var API_BASE='/api';
(function(){
  var KEY='xb-theme',root=document.documentElement,btn=document.getElementById('themeBtn');
  function apply(t){
    root.setAttribute('data-theme',t);
    if(btn)btn.textContent=t==='dark'?'☀':'☾';
  }
  apply(localStorage.getItem(KEY)||'light');
  if(btn)btn.onclick=function(){
    var t=(localStorage.getItem(KEY)||'light')==='dark'?'light':'dark';
    localStorage.setItem(KEY,t);apply(t);
  };
})();
(function(){
  var lst=document.getElementById('lst');
  var pagerEl=document.getElementById('pager');
  var bcEl=document.getElementById('bc');
  var searchInput=document.getElementById('s');
  var currentCat='all',currentPage=1,searchTimer;

  var pathCat=location.pathname.replace(/^\//,'').replace(/\/$/,'');
  var CAT_SLUGS=Object.keys(CAT_LABELS);
  var pathCatValid=CAT_SLUGS.indexOf(pathCat)!==-1?pathCat:null;
  var savedQ=(new URLSearchParams(location.search)).get('q')||'';
  // 搜索时强制全站搜索（cat=all），忽略栏目记忆
  var saved=savedQ?'all':(pathCatValid||(new URLSearchParams(location.search)).get('cat')||localStorage.getItem('xb-cat')||'all');
  if(saved==='huishou'){
    localStorage.setItem('xb-cat','all');
    window.location.href='/huishou/';
    return;
  }
  if(saved&&saved!=='all'){
    currentCat=saved;
    document.querySelectorAll('.cat-pill').forEach(function(p){p.classList.toggle('on',p.getAttribute('data-cat')===currentCat)});
  }
  // 有搜索词时高亮"全部"标签
  if(savedQ){
    currentCat='all';
    document.querySelectorAll('.cat-pill').forEach(function(p){p.classList.toggle('on',p.getAttribute('data-cat')==='all')});
  }
  localStorage.setItem('xb-cat',currentCat);
  if(savedQ&&searchInput)searchInput.value=savedQ;

  function esc(s){var d=document.createElement('div');d.textContent=s;return d.innerHTML}

  function getBlocked(){try{return JSON.parse(localStorage.getItem('xb-blocked')||'[]')}catch(e){return []}}
  function applyBlockedDOM(){
    var blocked=getBlocked();
    if(!blocked.length)return;
    var rows=document.querySelectorAll('#lst .r');
    for(var i=0;i<rows.length;i++){
      var cat=rows[i].getAttribute('data-cat')||'';
      rows[i].style.display=blocked.indexOf(cat)!==-1?'none':'';
    }
  }
  applyBlockedDOM();

  function renderList(items){
    if(!items||!items.length){
      lst.innerHTML='<div class="emp">暂无数据</div>';
      return;
    }
    var blocked=getBlocked();
    var h='';
    for(var i=0;i<items.length;i++){
      var a=items[i];
      var cs=a.cat_slug||'other';
      if(blocked.indexOf(cs)!==-1)continue;
      var ci=CAT_CHARS[cs]||CAT_CHARS['other'];
      var pin=a.is_pinned==1;
      var title=a.title||'';
      var displayTime=a.shorttime||'';
      if(a.datetime&&a.shorttime){
        var dm=a.datetime.match(/\d{4}[\-\/](\d{1,2})[\-\/](\d{1,2})/);
        if(dm){displayTime=dm[1].padStart(2,'0')+'-'+dm[2].padStart(2,'0')+' '+a.shorttime;}
      }
      h+='<a class="r'+(pin?' pinned':'')+'" href="/'+cs+'/'+a.id+'.html" data-cat="'+esc(cs)+'">'
        +(pin?'<span class="pin-badge">📌</span>':'')
        +'<span class="cat-badge" style="background:'+ci.color+'">'+esc(ci.char)+'</span>'
        +'<div class="bd"><div class="tt"><span class="title-text">'+esc(title)+'</span>'
        +(a.comment_count&&parseInt(a.comment_count)>0?'<span class="cmt-badge">💬'+parseInt(a.comment_count)+'</span>':'')
        +'<span class="tm">'+esc(displayTime)+'</span></div></div>'
        +'<span class="ar">›</span></a>';
    }
    lst.innerHTML=h;
  }

  function renderPager(page,total,totalItems){
    if(total<=1){pagerEl.innerHTML='';return}
    var h='<a href="#" class="'+(page<=1?'disabled':'')+'" data-p="'+(page-1)+'">‹ 上页</a>';
    var s=Math.max(1,page-3),e=Math.min(total,page+3);
    if(s>1){h+='<a href="#" data-p="1">1</a>';if(s>2)h+='<span class="dot">…</span>';}
    for(var i=s;i<=e;i++)h+=(i===page)?'<span class="on">'+i+'</span>':'<a href="#" data-p="'+i+'">'+i+'</a>';
    if(e<total){if(e<total-1)h+='<span class="dot">…</span>';h+='<a href="#" data-p="'+total+'">'+total+'</a>';}
    h+='<a href="#" class="'+(page>=total?'disabled':'')+'" data-p="'+(page+1)+'">下页 ›</a>';
    h+='<span class="dot">共 '+totalItems+' 篇</span>';
    pagerEl.innerHTML=h;
  }

  function loadPage(page,q,skipRender){
    currentPage=page;
    // 搜索时搜全站（cat=all），不限制当前栏目
    var searchCat = q ? 'all' : currentCat;
    var url=API_BASE+'/articles?page='+page+'&cat='+encodeURIComponent(searchCat);
    if(q)url+='&q='+encodeURIComponent(q);
    fetch(url).then(function(r){return r.json()}).then(function(d){
      if(!skipRender)renderList(d.items);
      renderPager(d.page,d.total_pages,d.total);
      if(bcEl)bcEl.textContent=d.total+' 条';
    }).catch(function(){});
  }

  document.querySelector('.cat-bar-inner').addEventListener('click',function(e){
    var t=e.target.closest('.cat-pill');
    if(!t)return;
    e.preventDefault();
    var cat=t.getAttribute('data-cat')||'all';
    if(cat==='huishou'){
      window.location.href='/huishou/';
      return;
    }
    // 标签汇总页：直接跳转，不走AJAX加载
    var href=t.getAttribute('href')||'';
    if(href.indexOf('/tags/')===0){
      window.location.href=href;
      return;
    }
    document.querySelectorAll('.cat-pill').forEach(function(a){a.classList.remove('on')});
    t.classList.add('on');
    currentCat=cat;
    localStorage.setItem('xb-cat',currentCat);
    history.replaceState(null,'',currentCat==='all'?'/':'/'+currentCat+'/');
    if(searchInput)searchInput.value='';
    loadPage(1);
  });

  pagerEl.addEventListener('click',function(e){
    var t=e.target.closest('a');
    if(!t||t.classList.contains('disabled'))return;
    e.preventDefault();
    var p=parseInt(t.getAttribute('data-p'));
    if(p>0)loadPage(p);
  });

  if(searchInput){
    searchInput.addEventListener('input',function(){
      clearTimeout(searchTimer);
      var self=this;
      searchTimer=setTimeout(function(){
        loadPage(1,self.value.toLowerCase().trim()||null);
      },300);
    });
  }

  loadPage(1, savedQ || null, !savedQ);
  var cdEl=document.getElementById('cdNum');
  var cd=20,maxSeenId=0;
  var allItems=document.querySelectorAll('.r');
  for(var i=0;i<allItems.length;i++){
    var href=allItems[i].getAttribute('href')||'';
    var m=href.match(/\/(\d+)\.html$/);
    if(m){var id=parseInt(m[1]);if(id>maxSeenId)maxSeenId=id;}
  }
  setInterval(function(){
    if(!cdEl)return;
    cd--;
    if(cd<=0){
      cd=20;
      fetch('/push.json').then(function(r){return r.json()}).then(function(data){
        if(!data||!data.length)return;
        var maxId=0;
        for(var i=0;i<data.length;i++){var id=data[i].id||0;if(id>maxId)maxId=id;}
        if(maxId>maxSeenId){
          maxSeenId=maxId;
          var qVal=searchInput?searchInput.value.toLowerCase().trim():'';
          loadPage(1,qVal||null,false);
        }
      }).catch(function(){});
      return;
    }
    cdEl.textContent=cd;
  },1000);
})();
(function(){
  var btn=document.getElementById('settingsBtn');
  var modal=document.getElementById('settingsModal');
  var close=document.getElementById('settingsClose');
  if(!btn||!modal)return;
  function get(){try{return JSON.parse(localStorage.getItem('xb-blocked')||'[]')}catch(e){return []}}
  function save(v){localStorage.setItem('xb-blocked',JSON.stringify(v))}
  var blocked=get();
  modal.querySelectorAll('[data-block-cat]').forEach(function(cb){
    cb.checked=blocked.indexOf(cb.getAttribute('data-block-cat'))===-1;
  });
  btn.onclick=function(){modal.classList.add('show')};
  close.onclick=function(){modal.classList.remove('show')};
  modal.onclick=function(e){if(e.target===modal)modal.classList.remove('show')};
  modal.querySelectorAll('[data-block-cat]').forEach(function(cb){
    cb.onchange=function(){
      var cat=cb.getAttribute('data-block-cat');
      var list=get();
      var idx=list.indexOf(cat);
      if(!cb.checked&&idx===-1)list.push(cat);
      if(cb.checked&&idx!==-1)list.splice(idx,1);
      save(list);
      var si=document.getElementById('s');
      var q=si?si.value.toLowerCase().trim():'';
      var active=document.querySelector('.cat-pill.on');
      if(active)currentCat=active.getAttribute('data-cat')||'all';
      loadPage(1,q||null,false);
    };
  });
})();
(function(){
  var btn=document.getElementById('searchBtn');
  var modal=document.getElementById('searchModal');
  var close=document.getElementById('searchClose');
  var input=document.getElementById('searchModalInput');
  var mainInput=document.getElementById('s');
  if(!btn||!modal)return;
  btn.onclick=function(){
    modal.classList.add('show');
    if(input)input.value=mainInput?mainInput.value:'';
    setTimeout(function(){if(input)input.focus()},100);
  };
  close.onclick=function(){modal.classList.remove('show')};
  modal.onclick=function(e){if(e.target===modal)modal.classList.remove('show')};
  if(input){
    input.addEventListener('keydown',function(e){
      if(e.key==='Enter'){
        if(mainInput)mainInput.value=input.value;
        mainInput.dispatchEvent(new Event('input'));
        modal.classList.remove('show');
      }
    });
  }
})();
(function(){
  var BASE=API_BASE+'/rank?key=';
  var cache={},cur='yixiaoshi';
  var tabs=document.getElementById('rankTabs');
  var lst=document.getElementById('rankLst');
  function esc(s){var d=document.createElement('div');d.textContent=s;return d.innerHTML}
  function render(items){
    if(!items||!items.length){lst.innerHTML='<div class="emp">暂无数据</div>';return}
    var h='';
    for(var i=0;i<items.length;i++){
      var it=items[i],cat=it.cat_slug||'other';
      h+='<a class="rank-r" href="/?q='+encodeURIComponent(it.title)+'" data-rank-q="'+esc(it.title)+'">'
        +'<span class="rank-no">'+(i+1)+'</span>'
        +'<div class="rank-bd"><div class="rank-tt">'+esc(it.title)+'</div>'
        +'<div class="rank-meta"><span class="rank-cmt">💬 '+(it.comments||'0')+'</span>'
        +(it.catename?'<span class="rank-cate">'+esc(it.catename)+'</span>':'')
        +(it.shorttime?'<span class="rank-tm">'+esc(it.shorttime)+'</span>':'')
        +'</div></div><span class="rank-ar">›</span></a>';
    }
    lst.innerHTML=h;
  }
  function load(key){
    cur=key;
    if(cache[key]){render(cache[key]);return}
    lst.innerHTML='<div class="loading"><div class="spinner"></div>加载中…</div>';
    fetch(BASE+key).then(function(r){return r.json()}).then(function(d){
      cache[key]=d;
      if(cur===key)render(d);
    }).catch(function(){lst.innerHTML='<div class="emp">加载失败</div>'});
  }
  tabs.addEventListener('click',function(e){
    var t=e.target.closest('.rank-tab');
    if(!t)return;
    tabs.querySelectorAll('.rank-tab').forEach(function(b){b.classList.remove('on')});
    t.classList.add('on');
    load(t.getAttribute('data-key'));
  });
  load('yixiaoshi');
  // 排行榜点击：在本页触发全站搜索，不跳新页面
  lst.addEventListener('click',function(e){
    var a=e.target.closest('.rank-r');
    if(!a)return;
    e.preventDefault();
    var q=a.getAttribute('data-rank-q');
    if(!q)return;
    var si=document.getElementById('s');
    if(si)si.value=q;
    si.dispatchEvent(new Event('input'));
  });
})();
(function(){
  var BASE=API_BASE+'/rank?key=';
  var cache={},cur='shierxiaoshi';
  var tabs=document.getElementById('longRankTabs');
  var lst=document.getElementById('longRankLst');
  if(!tabs||!lst)return;
  function esc(s){var d=document.createElement('div');d.textContent=s;return d.innerHTML}
  function render(items){
    if(!items||!items.length){lst.innerHTML='<div class=\"emp\">暂无数据</div>';return}
    var h='';
    for(var i=0;i<items.length;i++){
      var it=items[i],cat=it.cat_slug||'other';
      h+='<a class=\"rank-r\" href=\"/?q='+encodeURIComponent(it.title)+'\" data-rank-q=\"'+esc(it.title)+'\">'
        +'<span class=\"rank-no\">'+(i+1)+'</span>'
        +'<div class=\"rank-bd\"><div class=\"rank-tt\">'+esc(it.title)+'</div>'
        +'<div class=\"rank-meta\"><span class=\"rank-cmt\">💬 '+(it.comments||'0')+'</span>'
        +(it.catename?'<span class=\"rank-cate\">'+esc(it.catename)+'</span>':'')
        +(it.shorttime?'<span class=\"rank-tm\">'+esc(it.shorttime)+'</span>':'')
        +'</div></div><span class=\"rank-ar\">›</span></a>';
    }
    lst.innerHTML=h;
  }
  function load(key){
    cur=key;
    if(cache[key]){render(cache[key]);return}
    lst.innerHTML='<div class=\"loading\"><div class=\"spinner\"></div>加载中…</div>';
    fetch(BASE+key).then(function(r){return r.json()}).then(function(d){
      cache[key]=d;
      if(cur===key)render(d);
    }).catch(function(){lst.innerHTML='<div class=\"emp\">加载失败</div>'});
  }
  tabs.addEventListener('click',function(e){
    var t=e.target.closest('.rank-tab');
    if(!t)return;
    tabs.querySelectorAll('.rank-tab').forEach(function(b){b.classList.remove('on')});
    t.classList.add('on');
    load(t.getAttribute('data-key'));
  });
  load('shierxiaoshi');
  // 长时段排行榜点击：在本页触发全站搜索
  lst.addEventListener('click',function(e){
    var a=e.target.closest('.rank-r');
    if(!a)return;
    e.preventDefault();
    var q=a.getAttribute('data-rank-q');
    if(!q)return;
    var si=document.getElementById('s');
    if(si)si.value=q;
    si.dispatchEvent(new Event('input'));
  });
})();
// ========== 热门标签加载 ==========
(function(){
  var cloud=document.getElementById('tagCloud');
  if(!cloud)return;
  function esc(s){var d=document.createElement('div');d.textContent=s;return d.innerHTML}
  fetch(API_BASE+'/tags').then(function(r){return r.json()}).then(function(tags){
    if(!tags||!tags.length){cloud.innerHTML='<div class="emp">暂无标签</div>';return}
    var h='';
    // 标签云：按热度调整大小
    var maxCount=tags[0].count||1;
    for(var i=0;i<tags.length;i++){
      var t=tags[i];
      var ratio=Math.max(0.6, t.count/maxCount);
      var size=Math.round(12+ratio*8); // 12px-20px
      var weight=ratio>0.7?'700':ratio>0.4?'500':'400';
      h+='<a class="tag-item" href="/tags/'+encodeURIComponent(t.word)+'" style="font-size:'+size+'px;font-weight:'+weight+'">'+esc(t.word)+'<span class="tag-count">'+t.count+'</span></a>';
    }
    cloud.innerHTML=h;
  }).catch(function(){cloud.innerHTML='<div class="emp">加载失败</div>'});
})();
</script>
