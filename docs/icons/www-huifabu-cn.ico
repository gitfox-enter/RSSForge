  var _mtj = _mtj || [];
  (function () {
  var mtj = document.createElement("script");
  mtj.src = "https://node91.aizhantj.com:21233/tjjs/?k=rdbsabd6m77";
  var s = document.getElementsByTagName("script")[0];
  s.parentNode.insertBefore(mtj, s);
  })();
</script>
</body>
</html>
