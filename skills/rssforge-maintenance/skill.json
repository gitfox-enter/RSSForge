{
  "name": "rssforge-maintenance",
  "version": "1.0.0",
  "description": "RSSForge project maintenance skill with monitoring, auto-fix, and recovery capabilities",
  "author": "RSSForge Maintenance Agent",
  "repository": "https://github.com/gitfox-enter/RSSForge",
  "license": "MIT",

  "keywords": [
    "rssforge",
    "rss",
    "maintenance",
    "monitoring",
    "automation",
    "self-healing"
  ],

  "capabilities": [
    "monitor-rss-feeds",
    "check-site-availability",
    "auto-fix-data-issues",
    "generate-health-reports",
    "schedule-maintenance",
    "agent-recovery"
  ],

  "requirements": {
    "python": ">=3.8",
    "github_pat": "required",
    "network": "optional (for link checking)"
  },

  "configuration": {
    "github_pat": {
      "type": "string",
      "required": true,
      "description": "GitHub Personal Access Token with repo access",
      "env": "GITHUB_PAT"
    },
    "repository": {
      "type": "string",
      "default": "gitfox-enter/RSSForge",
      "description": "GitHub repository (owner/repo)"
    },
    "log_dir": {
      "type": "string",
      "default": "/tmp/rssforge-logs",
      "description": "Directory for log files"
    },
    "timezone": {
      "type": "string",
      "default": "Asia/Shanghai",
      "description": "Timezone for scheduled tasks"
    }
  },

  "schedule": {
    "daily_monitor": {
      "cron": "5 7,12,18,23 * * *",
      "timezone": "Asia/Shanghai",
      "task": "python3 scripts/monitor_enhanced.py --pat $GITHUB_PAT",
      "description": "Daily quality check (4x per day)"
    },
    "weekly_maintenance": {
      "cron": "0 23 * * 0",
      "timezone": "Asia/Shanghai",
      "task": "python3 scripts/auto_fix.py --pat $GITHUB_PAT",
      "description": "Weekly deep maintenance (Sunday 23:00)"
    }
  },

  "files": {
    "skill_definition": "SKILL.md",
    "scripts": [
      "scripts/monitor_enhanced.py",
      "scripts/auto_fix.py",
      "scripts/diagnose_feeds.py"
    ],
    "documentation": [
      "docs/MAINTENANCE_PLAN.md",
      "docs/QUICK_REFERENCE.md"
    ],
    "examples": [
      "examples/EXAMPLES.md"
    ]
  },

  "metrics": {
    "current_health_ratio": 25,
    "target_health_ratio": 90,
    "total_sites": 48,
    "healthy_sites": 12,
    "zero_count_sites": 36
  },

  "last_updated": "2026-07-11T16:45:00+08:00",
  "status": "production"
}
